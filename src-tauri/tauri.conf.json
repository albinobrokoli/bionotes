{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BioNotes",
  "version": "0.1.1",
  "identifier": "org.sinirbilimportali.bionotes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BioNotes",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0E0E10"
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: data: blob: filesystem: ws: wss: http: https:; connect-src 'self' https://api.crossref.org http://ipc.localhost tauri:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:bionotes.db"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ4QjFDMDcxNTQ0RTc0NjgKUldSb2RFNVVjY0N4Mk1iWWVEaFJMeTFVckJxMXhvQmJ0YWppS01uRFZVN3pWWHBnSXcrb2R5dWEK",
      "endpoints": ["https://github.com/albinobrokoli/bionotes/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "category": "public.app-category.productivity",
    "shortDescription": "Open-source, local-first note-taking app for science students",
    "longDescription": "BioNotes is an open-source, local-first note-taking app built for biology, medicine, chemistry, and physics students. PDF annotation, LaTeX support, source tracking, and science-focused blocks.",
    "copyright": "Copyright © 2026 Sinirbilim Portalı",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  }
}
